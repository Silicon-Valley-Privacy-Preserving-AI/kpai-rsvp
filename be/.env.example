PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001,https://example.domain.com

# PostgreSQL connection URL
# When running via docker-compose the host is the service name "postgres".
# For local (non-Docker) development use "localhost" instead.
DATABASE_URL=postgresql+asyncpg://svain:svainpassword@postgres:5432/svain

# SECRET_KEY for password hash pepper
SECRET_KEY="It's secret"

# SECRET for JWT
JWT_SECRET="It's not secret"
ALGORITHM=HS256
TOKEN_LIFETIME_MINUTE=

# Staff role code
STAFF_CODE=SUPERSECRET123

# SMTP (optional) — leave blank to skip email sending
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@svain.ai
